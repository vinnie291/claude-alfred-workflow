				<string>// Helpers
function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function readChat(path) {
  const chatString = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined).js
  return JSON.parse(chatString)
}

function markdownChat(messages, ignoreLastInterrupted = true) {
  const items = []
  messages.forEach((m, i, all) =&gt; {
    if (m["role"] === "user") {
      const userTwice = all[i + 1]?.["role"] === "user"
      const isLast = i === all.length - 1
      const quoted = m["content"].split("\n").map(l =&gt; `&gt; ${l}`).join("\n")
      let block = quoted
      if (userTwice || (isLast &amp;&amp; !ignoreLastInterrupted)) {
        block += `\n\n[Answer Interrupted]`
      }
      items.push({ type: "user", text: block })
      if (isLast &amp;&amp; ignoreLastInterrupted) items.push({ type: "claude", text: `## Claude` })
    } else if (m["role"] === "assistant") {
      items.push({ type: "claude", text: `## Claude\n\n${m["content"]}` })
    }
  })
  let out = ""
  items.forEach((it, idx) =&gt; {
    if (idx &gt; 0) out += it.type === "user" ? "\n\n---\n\n" : "\n\n"
    out += it.text
  })
  return out + "\n\n"
}

// Main
function run() {
  const chatFile = `${envVar("alfred_workflow_data")}/chat.json`
  return markdownChat(readChat(chatFile), false)
}</string>
