#!/usr/bin/osascript -l JavaScript

// Helpers
function envVar(varName) {
  return $.NSProcessInfo
    .processInfo
    .environment
    .objectForKey(varName).js
}

function fileExists(path) {
  return $.NSFileManager.defaultManager.fileExistsAtPath(path)
}

function fileModified(path) {
  return $.NSFileManager.defaultManager
    .attributesOfItemAtPathError(path, undefined)
    .js["NSFileModificationDate"].js
    .getTime()
}

function deleteFile(path) {
  return $.NSFileManager.defaultManager.removeItemAtPathError(path, undefined)
}

function writeFile(path, text) {
  $(text).writeToFileAtomicallyEncodingError(path, true, $.NSUTF8StringEncoding, undefined)
}

function readChat(path) {
  if (!fileExists(path)) return []
  const chatString = $.NSString.stringWithContentsOfFileEncodingError(path, $.NSUTF8StringEncoding, undefined).js
  try { return JSON.parse(chatString) } catch { return [] }
}

function appendChat(path, message) {
  const ongoingChat = readChat(path).concat(message)
  writeFile(path, JSON.stringify(ongoingChat))
}

function markdownChat(messages, ignoreLastInterrupted = true) {
  const items = []
  messages.forEach((m, i, all) => {
    if (m["role"] === "user") {
      const userTwice = all[i + 1]?.["role"] === "user"
      const isLast = i === all.length - 1
      const quoted = m["content"].split("\n").map(l => `> ${l}`).join("\n")
      let block = quoted
      if (userTwice || (isLast && !ignoreLastInterrupted)) {
        block += `\n\n[Answer Interrupted]`
      }
      items.push({ type: "user", text: block })
      if (isLast && ignoreLastInterrupted) items.push({ type: "claude", text: `## Claude` })
    } else if (m["role"] === "assistant") {
      items.push({ type: "claude", text: `## Claude\n\n${m["content"]}` })
    }
  })
  let out = ""
  items.forEach((it, idx) => {
    if (idx > 0) out += it.type === "user" ? "\n\n---\n\n" : "\n\n"
    out += it.text
  })
  return out + "\n\n"
}

function startStream(apiEndpoint, apiKey, model, maxTokens, systemPrompt, contextChat, streamFile, pidStreamFile, timeoutSeconds) {
  $.NSFileManager.defaultManager.createFileAtPathContentsAttributes(streamFile, undefined, undefined)

  const body = {
    model: model,
    max_tokens: maxTokens,
    messages: contextChat,
    stream: true
  }
  if (systemPrompt) body.system = systemPrompt

  const task = $.NSTask.alloc.init
  const stdout = $.NSPipe.pipe

  task.executableURL = $.NSURL.fileURLWithPath("/usr/bin/curl")
  task.arguments = [
    apiEndpoint,
    "--speed-limit", "0", "--speed-time", timeoutSeconds.toString(),
    "--silent", "--no-buffer",
    "--header", "content-type: application/json",
    "--header", `x-api-key: ${apiKey}`,
    "--header", "anthropic-version: 2023-06-01",
    "--data", JSON.stringify(body),
    "--output", streamFile
  ]

  task.standardOutput = stdout
  task.launchAndReturnError(false)
  writeFile(pidStreamFile, task.processIdentifier.toString())
}

function readStream(streamFile, chatFile, pidStreamFile, timeoutSeconds) {
  const streamMarker = envVar("stream_marker") === "1"
  const streamString = $.NSString.stringWithContentsOfFileEncodingError(streamFile, $.NSUTF8StringEncoding, undefined).js

  if (streamMarker) return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true },
    response: "…",
    behaviour: { response: "append" }
  })

  // Error body (non-stream JSON) starts with "{"
  if (streamString.startsWith("{")) {
    try {
      const parsed = JSON.parse(streamString)
      const errorMessage = parsed?.error?.message || parsed?.message
      if (errorMessage) {
        deleteFile(streamFile)
        deleteFile(pidStreamFile)
        return JSON.stringify({
          response: errorMessage,
          behaviour: { response: "replacelast" }
        })
      }
      throw "no message"
    } catch {
      return JSON.stringify({
        response: streamString,
        behaviour: { response: "replacelast" }
      })
    }
  }

  // Parse Anthropic SSE: lines `data: {...}` between event lines
  const events = streamString
    .split("\n")
    .filter(line => line.startsWith("data: "))
    .map(line => line.replace(/^data: /, ""))
    .flatMap(item => { try { return [JSON.parse(item)] } catch { return [] } })

  const responseText = events
    .filter(e => e.type === "content_block_delta" && e.delta?.type === "text_delta")
    .map(e => e.delta.text)
    .join("")

  // Detect error events embedded mid-stream
  const errorEvent = events.find(e => e.type === "error")
  if (errorEvent) {
    if (responseText.length > 0) appendChat(chatFile, { role: "assistant", content: responseText })
    deleteFile(streamFile)
    deleteFile(pidStreamFile)
    return JSON.stringify({
      response: `${responseText}\n\n[Error: ${errorEvent.error?.message || "unknown"}]`,
      behaviour: { response: "replacelast", scroll: "end" }
    })
  }

  // stop_reason arrives in message_delta; message_stop confirms end
  const messageDelta = events.findLast(e => e.type === "message_delta")
  const stopReason = messageDelta?.delta?.stop_reason
  const finished = events.some(e => e.type === "message_stop") || stopReason

  if (!finished) {
    const stalled = new Date().getTime() - fileModified(streamFile) > timeoutSeconds * 1000

    if (stalled) {
      if (responseText.length > 0) appendChat(chatFile, { role: "assistant", content: responseText })
      deleteFile(streamFile)
      deleteFile(pidStreamFile)
      return JSON.stringify({
        response: `${responseText} [Connection Stalled]`,
        footer: "You can ask Claude to continue the answer",
        behaviour: { response: "replacelast", scroll: "end" }
      })
    }

    if (streamString.length === 0) return JSON.stringify({
      rerun: 0.1,
      variables: { streaming_now: true }
    })

    return JSON.stringify({
      rerun: 0.1,
      variables: { streaming_now: true },
      response: responseText,
      behaviour: { response: "replacelast", scroll: "end" }
    })
  }

  // Finished
  appendChat(chatFile, { role: "assistant", content: responseText })
  deleteFile(streamFile)
  deleteFile(pidStreamFile)

  const footerText = (function() {
    switch (stopReason) {
      case "max_tokens": return "Maximum number of tokens reached"
      case "stop_sequence": return "Stop sequence reached"
      case "refusal": return "Claude declined to respond"
    }
  })()

  return JSON.stringify({
    response: responseText,
    footer: footerText,
    behaviour: { response: "replacelast", scroll: "end" }
  })
}

function run(argv) {
  const typedQuery = argv[0] || ""
  const maxContext = parseInt(envVar("max_context") || "20")
  const timeoutSeconds = parseInt(envVar("timeout_seconds") || "8")
  const apiKey = envVar("anthropic_api_key") || ""
  const apiEndpoint = envVar("claude_api_endpoint") || "https://api.anthropic.com/v1/messages"
  const systemPrompt = envVar("system_prompt") || ""
  const model = envVar("claude_model_override") || envVar("claude_model") || "claude-opus-4-7"
  const maxTokens = parseInt(envVar("max_tokens") || "2048")
  const chatFile = `${envVar("alfred_workflow_data")}/chat.json`
  const pidStreamFile = `${envVar("alfred_workflow_cache")}/pid.txt`
  const streamFile = `${envVar("alfred_workflow_cache")}/stream.txt`
  const streamingNow = envVar("streaming_now") === "1"

  // Ensure data + cache dirs exist
  $.NSFileManager.defaultManager.createDirectoryAtPathWithIntermediateDirectoriesAttributesError(envVar("alfred_workflow_data"), true, undefined, undefined)
  $.NSFileManager.defaultManager.createDirectoryAtPathWithIntermediateDirectoriesAttributesError(envVar("alfred_workflow_cache"), true, undefined, undefined)

  if (!apiKey) return JSON.stringify({
    response: "ANTHROPIC API key not set.\n\nOpen Alfred → Workflows → Claude → [x] icon → Configure Workflow… and paste your key from console.anthropic.com.",
    behaviour: { response: "replacelast" }
  })

  if (streamingNow) return readStream(streamFile, chatFile, pidStreamFile, timeoutSeconds)

  const previousChat = readChat(chatFile)

  // Stream file exists but streaming_now unset → window was closed mid-stream
  if (fileExists(streamFile)) return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true, stream_marker: true },
    response: markdownChat(previousChat, true),
    behaviour: { scroll: "end" }
  })

  // Empty query → show prior chat
  if (typedQuery.length === 0) return JSON.stringify({
    response: markdownChat(previousChat, false),
    behaviour: { scroll: "end" }
  })

  // New question
  const appendQuery = { role: "user", content: typedQuery }
  const ongoingChat = previousChat.concat(appendQuery)
  const contextChat = ongoingChat.slice(-maxContext)

  startStream(apiEndpoint, apiKey, model, maxTokens, systemPrompt, contextChat, streamFile, pidStreamFile, timeoutSeconds)
  appendChat(chatFile, appendQuery)

  return JSON.stringify({
    rerun: 0.1,
    variables: { streaming_now: true, stream_marker: true },
    response: markdownChat(ongoingChat)
  })
}
